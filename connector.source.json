{
  "schemaVersion": 1,
  "extensionId": "irodori.arangodb",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "arangodb.connector",
    "engine": "arangodb",
    "label": "ArangoDB",
    "aliases": [
      "arangodb",
      "ArangoDB"
    ],
    "defaultPort": 8529,
    "wire": "graph",
    "module": "arangodb.driver",
    "features": [
      "metadata",
      "graph",
      "graphVisualization",
      "pathFinding",
      "graphAlgorithms",
      "queryTemplates",
      "visualization"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "hostPort",
        "connectionString"
      ],
      "defaultPort": 8529,
      "fields": [
        {
          "id": "host",
          "label": "Host",
          "type": "string",
          "profileField": "host",
          "required": true
        },
        {
          "id": "port",
          "label": "Port",
          "type": "number",
          "profileField": "port",
          "default": 8529
        },
        {
          "id": "database",
          "label": "Database",
          "type": "string",
          "profileField": "database"
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "basic",
      "jwt",
      "clientCertificate",
      "customDriverOptions"
    ],
    "tls": "optional",
    "transports": "default",
    "optionNamespaces": [
      "graph",
      "arangodb"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  },
  "experience": {
    "schemaVersion": 1,
    "domains": [
      "graph"
    ],
    "inspiredBy": [
      "ArangoDB Web Interface Graph Viewer",
      "AQL graph traversals",
      "AQL shortest path"
    ],
    "resultViews": [
      "graph",
      "path",
      "table",
      "json"
    ],
    "objectTypes": [
      "graphs",
      "vertexCollections",
      "edgeCollections",
      "indexes",
      "analyzers"
    ],
    "workflows": [
      {
        "id": "graph-neighborhood",
        "label": "Explore neighborhood",
        "description": "Start from one vertex and return the surrounding path objects.",
        "resultView": "graph",
        "templateIds": [
          "graph-aql-neighborhood"
        ]
      },
      {
        "id": "graph-shortest-path",
        "label": "Shortest path",
        "description": "Trace the shortest route between two vertices in a named graph.",
        "resultView": "path",
        "templateIds": [
          "graph-aql-shortest-path"
        ]
      },
      {
        "id": "graph-collection-sample",
        "label": "Collection sample",
        "description": "Inspect vertex or edge documents before building a traversal.",
        "resultView": "table",
        "templateIds": [
          "graph-aql-sample"
        ]
      }
    ],
    "queryTemplates": [
      {
        "id": "graph-aql-neighborhood",
        "label": "Neighborhood traversal",
        "language": "aql",
        "description": "Return paths around a starting vertex.",
        "insertText": "FOR v, e, p IN 1..2 ANY @startVertex GRAPH @graphName\n  LIMIT @limit\n  RETURN p",
        "parameters": [
          {
            "id": "graphName",
            "label": "Graph name",
            "type": "string"
          },
          {
            "id": "startVertex",
            "label": "Start vertex id",
            "type": "string"
          },
          {
            "id": "limit",
            "label": "Limit",
            "type": "number",
            "default": 25
          }
        ],
        "resultView": "graph"
      },
      {
        "id": "graph-aql-shortest-path",
        "label": "Shortest path",
        "language": "aql",
        "description": "Find the shortest path between source and target vertices.",
        "insertText": "FOR v, e, p IN OUTBOUND SHORTEST_PATH @source TO @target GRAPH @graphName\n  RETURN p",
        "parameters": [
          {
            "id": "graphName",
            "label": "Graph name",
            "type": "string"
          },
          {
            "id": "source",
            "label": "Source vertex id",
            "type": "string"
          },
          {
            "id": "target",
            "label": "Target vertex id",
            "type": "string"
          }
        ],
        "resultView": "path"
      },
      {
        "id": "graph-aql-sample",
        "label": "Collection sample",
        "language": "aql",
        "description": "Preview graph collection documents.",
        "insertText": "FOR doc IN @@collection\n  LIMIT @limit\n  RETURN doc",
        "parameters": [
          {
            "id": "collection",
            "label": "Collection",
            "type": "string"
          },
          {
            "id": "limit",
            "label": "Limit",
            "type": "number",
            "default": 25
          }
        ],
        "resultView": "table"
      }
    ],
    "inspectorHints": [
      {
        "id": "graph-name",
        "label": "Graph selector",
        "description": "Expose named graphs alongside vertex and edge collections."
      },
      {
        "id": "edge-direction",
        "label": "Direction toggle",
        "description": "Let users switch OUTBOUND, INBOUND, and ANY traversal direction."
      }
    ]
  }
}
