{
  "$schema": "https://irodori.dev/schemas/irodori.extension.schema.json",
  "manifestVersion": 1,
  "id": "irodori.arangodb",
  "name": "ArangoDB Connector",
  "version": "0.1.0",
  "publisher": "irodori",
  "description": "ArangoDB Connector contributes the ArangoDB database connector through the native connector ABI.",
  "license": "MIT OR 0BSD",
  "repository": "https://github.com/hjosugi/irodori-extension-arangodb",
  "apiVersion": "0.1",
  "runtime": "native",
  "entry": "dist/native",
  "permissions": [
    "connections:read",
    "connections:write",
    "queries:run",
    "metadata:read",
    "native",
    "connectors"
  ],
  "contributes": {
    "connectors": [
      {
        "id": "arangodb.connector",
        "engine": "arangodb",
        "label": "ArangoDB",
        "aliases": [
          "arangodb",
          "ArangoDB"
        ],
        "defaultPort": 8529,
        "wire": "graph",
        "module": "arangodb.driver",
        "features": [
          "metadata",
          "graph",
          "graphVisualization",
          "pathFinding",
          "graphAlgorithms",
          "queryTemplates",
          "visualization"
        ],
        "connection": {
          "schemaVersion": 1,
          "inferEnvironmentFrom": [
            "name",
            "id",
            "host",
            "database",
            "url"
          ],
          "compatibility": {
            "addsRequiredProfileFields": false,
            "acceptsExistingProfiles": true
          },
          "defaults": {
            "engine": "arangodb",
            "wire": "graph",
            "port": 8529,
            "readOnly": false
          },
          "endpoint": {
            "modes": [
              "hostPort",
              "connectionString"
            ],
            "defaultPort": 8529,
            "fields": [
              {
                "id": "host",
                "label": "Host",
                "type": "string",
                "profileField": "host",
                "required": true
              },
              {
                "id": "port",
                "label": "Port",
                "type": "number",
                "profileField": "port",
                "default": 8529
              },
              {
                "id": "database",
                "label": "Database",
                "type": "string",
                "profileField": "database"
              }
            ]
          },
          "profileFields": [
            {
              "id": "id",
              "label": "Connection ID",
              "type": "string",
              "profileField": "id",
              "required": true
            },
            {
              "id": "url",
              "label": "Connection URL or DSN",
              "type": "uri",
              "profileField": "url"
            },
            {
              "id": "user",
              "label": "User",
              "type": "string",
              "profileField": "user"
            },
            {
              "id": "host",
              "label": "Host",
              "type": "string",
              "profileField": "host",
              "required": true
            },
            {
              "id": "port",
              "label": "Port",
              "type": "number",
              "profileField": "port",
              "default": 8529
            },
            {
              "id": "database",
              "label": "Database",
              "type": "string",
              "profileField": "database"
            },
            {
              "id": "readOnly",
              "label": "Read-only connection",
              "type": "boolean",
              "profileField": "readOnly",
              "default": false
            },
            {
              "id": "options",
              "label": "Driver options",
              "type": "map",
              "profileField": "options"
            }
          ],
          "authMethods": [
            {
              "id": "none",
              "label": "No authentication",
              "kind": "none",
              "secretPurposes": [],
              "fields": []
            },
            {
              "id": "connectionString",
              "label": "Connection string / DSN",
              "kind": "connectionString",
              "secretPurposes": [],
              "fields": [
                {
                  "id": "url",
                  "label": "Connection URL or DSN",
                  "type": "uri",
                  "profileField": "url",
                  "required": true
                }
              ]
            },
            {
              "id": "basic",
              "label": "Basic authentication",
              "kind": "userPassword",
              "secretPurposes": [
                "password"
              ],
              "fields": [
                {
                  "id": "user",
                  "label": "User",
                  "type": "string",
                  "profileField": "user"
                },
                {
                  "id": "password",
                  "label": "Password",
                  "type": "secret",
                  "secretPurpose": "password",
                  "profileField": "password"
                }
              ]
            },
            {
              "id": "jwt",
              "label": "JWT bearer token",
              "kind": "token",
              "secretPurposes": [
                "token"
              ],
              "fields": [
                {
                  "id": "token",
                  "label": "Token",
                  "type": "secret",
                  "secretPurpose": "token"
                }
              ]
            },
            {
              "id": "clientCertificate",
              "label": "Client certificate / mTLS",
              "kind": "certificate",
              "secretPurposes": [
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "clientCertificate",
                  "label": "Client certificate",
                  "type": "pem"
                },
                {
                  "id": "clientPrivateKey",
                  "label": "Client private key",
                  "type": "pem",
                  "secretPurpose": "privateKey"
                },
                {
                  "id": "clientPrivateKeyPassphrase",
                  "label": "Private key passphrase",
                  "type": "secret",
                  "secretPurpose": "privateKeyPassphrase"
                }
              ]
            },
            {
              "id": "customDriverOptions",
              "label": "Custom driver options",
              "kind": "custom",
              "secretPurposes": [
                "password",
                "token",
                "privateKey",
                "privateKeyPassphrase"
              ],
              "fields": [
                {
                  "id": "options",
                  "label": "Driver options",
                  "type": "map",
                  "profileField": "options"
                }
              ]
            }
          ],
          "secretPurposes": [
            "password",
            "token",
            "privateKey",
            "privateKeyPassphrase"
          ],
          "tls": {
            "supported": true,
            "requiredByDefault": false,
            "modes": [
              "disable",
              "prefer",
              "require",
              "verifyCa",
              "verifyFull",
              "clientCertificate"
            ],
            "fields": [
              {
                "id": "caCertificate",
                "label": "CA certificate",
                "type": "pem"
              },
              {
                "id": "clientCertificate",
                "label": "Client certificate",
                "type": "pem"
              },
              {
                "id": "clientPrivateKey",
                "label": "Client private key",
                "type": "pem",
                "secretPurpose": "privateKey"
              }
            ]
          },
          "transports": [
            "direct",
            "sshTunnel",
            "socks5Proxy",
            "httpConnectProxy",
            "proxyChain"
          ],
          "optionNamespaces": [
            "profile.options",
            "driver",
            "tls",
            "network",
            "graph",
            "arangodb"
          ],
          "customDriverOptions": true
        },
        "experience": {
          "schemaVersion": 1,
          "domains": [
            "graph"
          ],
          "inspiredBy": [
            "ArangoDB Web Interface Graph Viewer",
            "AQL graph traversals",
            "AQL shortest path"
          ],
          "resultViews": [
            "graph",
            "path",
            "table",
            "json"
          ],
          "objectTypes": [
            "graphs",
            "vertexCollections",
            "edgeCollections",
            "indexes",
            "analyzers"
          ],
          "workflows": [
            {
              "id": "graph-neighborhood",
              "label": "Explore neighborhood",
              "description": "Start from one vertex and return the surrounding path objects.",
              "resultView": "graph",
              "templateIds": [
                "graph-aql-neighborhood"
              ]
            },
            {
              "id": "graph-shortest-path",
              "label": "Shortest path",
              "description": "Trace the shortest route between two vertices in a named graph.",
              "resultView": "path",
              "templateIds": [
                "graph-aql-shortest-path"
              ]
            },
            {
              "id": "graph-collection-sample",
              "label": "Collection sample",
              "description": "Inspect vertex or edge documents before building a traversal.",
              "resultView": "table",
              "templateIds": [
                "graph-aql-sample"
              ]
            }
          ],
          "queryTemplates": [
            {
              "id": "graph-aql-neighborhood",
              "label": "Neighborhood traversal",
              "language": "aql",
              "description": "Return paths around a starting vertex.",
              "insertText": "FOR v, e, p IN 1..2 ANY @startVertex GRAPH @graphName\n  LIMIT @limit\n  RETURN p",
              "parameters": [
                {
                  "id": "graphName",
                  "label": "Graph name",
                  "type": "string"
                },
                {
                  "id": "startVertex",
                  "label": "Start vertex id",
                  "type": "string"
                },
                {
                  "id": "limit",
                  "label": "Limit",
                  "type": "number",
                  "default": 25
                }
              ],
              "resultView": "graph"
            },
            {
              "id": "graph-aql-shortest-path",
              "label": "Shortest path",
              "language": "aql",
              "description": "Find the shortest path between source and target vertices.",
              "insertText": "FOR v, e, p IN OUTBOUND SHORTEST_PATH @source TO @target GRAPH @graphName\n  RETURN p",
              "parameters": [
                {
                  "id": "graphName",
                  "label": "Graph name",
                  "type": "string"
                },
                {
                  "id": "source",
                  "label": "Source vertex id",
                  "type": "string"
                },
                {
                  "id": "target",
                  "label": "Target vertex id",
                  "type": "string"
                }
              ],
              "resultView": "path"
            },
            {
              "id": "graph-aql-sample",
              "label": "Collection sample",
              "language": "aql",
              "description": "Preview graph collection documents.",
              "insertText": "FOR doc IN @@collection\n  LIMIT @limit\n  RETURN doc",
              "parameters": [
                {
                  "id": "collection",
                  "label": "Collection",
                  "type": "string"
                },
                {
                  "id": "limit",
                  "label": "Limit",
                  "type": "number",
                  "default": 25
                }
              ],
              "resultView": "table"
            }
          ],
          "inspectorHints": [
            {
              "id": "graph-name",
              "label": "Graph selector",
              "description": "Expose named graphs alongside vertex and edge collections."
            },
            {
              "id": "edge-direction",
              "label": "Direction toggle",
              "description": "Let users switch OUTBOUND, INBOUND, and ANY traversal direction."
            }
          ]
        }
      }
    ]
  },
  "capabilities": {
    "nativeModules": [
      {
        "id": "arangodb.driver",
        "path": "dist/native",
        "platforms": [
          "windowsX64",
          "windowsArm64",
          "macosX64",
          "macosArm64",
          "linuxX64",
          "linuxArm64"
        ]
      }
    ]
  },
  "dev": {
    "watch": [
      "src",
      "connector.config.json",
      "irodori.extension.json"
    ]
  }
}
